{ 
  "version": 2,
  "rewrites": [
    { 
      "source": "/(.*)", 
      "destination": "/api",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    { 
      "source": "/login", 
      "destination": "/api/login",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    }
  ],
  "builds": [
    { "src": "*.js", "use": "@vercel/node"}
  ]
}