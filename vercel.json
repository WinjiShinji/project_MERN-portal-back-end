{ 
  "version": 2,
  "builds": [
    { "src": "*.js", "use": "@vercel/node"}
  ],
  "rewrites": [
    { 
      "source": "/api/:path*",
      "destination": "https://localhost:3000/:path*",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    }
  ]
}